# functions/.secret.example — commit this file, NOT functions/.secret.local
#
# Copy this file to functions/.secret.local and fill in real values.
# functions/.secret.local is gitignored and must never be committed.
#
# This file is for local Cloud Functions secret testing ONLY.
# It is read by the Firebase Local Emulator Suite.
# It is never deployed to production.
#
# !! REVENUECAT_WEBHOOK_SECRET is server-only !!
# It must never be used in Flutter client code.
# It must never be passed to Flutter via --dart-define.
# Production Cloud Functions must use Firebase Secret Manager:
#   firebase functions:secrets:set REVENUECAT_WEBHOOK_SECRET
# See ENVIRONMENT_SETUP.md for full setup instructions.

# ── RevenueCat webhook Authorization ─────────────────────────────────────────
# This value is sent by RevenueCat as the Authorization header with each webhook
# POST request. The Cloud Function verifies it using constant-time comparison.
# Must match the value configured in:
#   RevenueCat Dashboard > Project > Webhooks > Authorization
REVENUECAT_WEBHOOK_SECRET=replace_with_revenuecat_webhook_authorization_value
