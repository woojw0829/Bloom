# Environment variable placeholders — copy to .env and fill in real values.
#
# NEVER commit .env or any file containing real secrets.
# .env is gitignored. Real secrets must not appear in version control.
#
# Production Cloud Functions must use Firebase Secret Manager.
# See ENVIRONMENT_SETUP.md for full setup instructions.

# ── RevenueCat webhook Authorization ─────────────────────────────────────────
# This value is sent by RevenueCat as the Authorization header with each webhook
# POST request. The Cloud Function verifies it using constant-time comparison.
# Must match the value you enter in:
#   RevenueCat Dashboard > Project > Webhooks > Authorization
# Set in Firebase Secret Manager before deploying:
#   firebase functions:secrets:set REVENUECAT_WEBHOOK_SECRET
REVENUECAT_WEBHOOK_SECRET=replace_with_revenuecat_webhook_authorization_value

# ── RevenueCat public SDK keys ────────────────────────────────────────────────
# Public keys from RevenueCat Dashboard > Project > Apps > (your app) > API keys.
# These are safe to include in client builds but must be injected via
# --dart-define, never hardcoded in source.
#   flutter run --dart-define=REVENUECAT_IOS_API_KEY=appl_... \
#               --dart-define=REVENUECAT_ANDROID_API_KEY=goog_...
REVENUECAT_IOS_API_KEY=appl_replace_with_public_ios_sdk_key
REVENUECAT_ANDROID_API_KEY=goog_replace_with_public_android_sdk_key
