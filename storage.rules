rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isValidUpload() {
      return isImage() && isUnder10MB();
    }

    function isMatchParticipant(matchId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/matches/$(matchId))
        && request.auth.uid in firestore.get(/databases/(default)/documents/matches/$(matchId)).data.users;
    }

    // ── Profile photos: users/{userId}/photos/{photoId} ───────────────────
    //
    // Any authenticated user may read profile photos (required for discovery
    // and chat). Only the owner may upload or delete their own photos.

    match /users/{userId}/photos/{photoId} {
      allow read:   if isSignedIn();
      allow create: if isOwner(userId) && isValidUpload();
      allow update: if isOwner(userId) && isValidUpload();
      allow delete: if isOwner(userId);
    }

    // ── Verification images: verifications/{userId}/{filename} ────────────
    //
    // Verification selfies and government ID images are write-only for the
    // owner. Client reads are BLOCKED — images are served exclusively through
    // short-lived signed URLs generated by a Cloud Function.
    // Ref: architecture.md — Firebase Storage / signed URL strategy.

    match /verifications/{userId}/{fileName} {
      allow create: if isOwner(userId) && isValidUpload();
      allow update: if isOwner(userId) && isValidUpload();
      allow read:   if false;
      allow delete: if false;
    }

    // ── Chat images: chats/{matchId}/{messageId} ───────────────────────────
    //
    // Only match participants may read or upload chat images. Participant
    // membership is verified via firestore.get() on the parent match document
    // (2 Firestore reads per Storage SDK operation).
    //
    // Note: Firebase Storage download URLs (returned by getDownloadURL()) are
    // tokenized and bypass Storage rules when accessed via HTTP. Access to
    // imageUrl values stored in Firestore is already gated by the Firestore
    // participant-only rule on messages, so non-participants cannot obtain URLs.

    match /chats/{matchId}/{messageId} {
      allow read:   if isMatchParticipant(matchId);
      allow create: if isMatchParticipant(matchId) && isValidUpload();
      allow delete: if false;
    }

    // ── Deny all other paths ──────────────────────────────────────────────

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
