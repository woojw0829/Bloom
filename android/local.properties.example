# local.properties.example — commit this file, NOT local.properties
#
# Copy this file to android/local.properties and fill in real values.
# android/local.properties is gitignored and must never be committed.
#
# Flutter SDK and Android SDK paths are written automatically by Android Studio / flutter.
# flutter.sdk=<path to Flutter SDK>
# sdk.dir=<path to Android SDK>

# Google Maps SDK for Android
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create an API key
# 3. Restrict it: Android apps | package com.wony.bloom | SHA-1 fingerprints | Maps SDK for Android
# 4. Paste the key below
MAPS_API_KEY=REDACTED_MAPS_ANDROID_API_KEY
