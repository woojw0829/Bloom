#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase config (sensitive)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# Environment / secret files — local only, never commit real secrets.
# Production Cloud Functions must use Firebase Secret Manager.
.env
.env.*
!.env.example
functions/.env
functions/.env.*
!functions/.env.example
functions/.secret.local
functions/.secret.*
.secret.local
.secret.*

# Node modules
node_modules/
functions/node_modules/
