# .env.flutter.example — commit this file, NOT .env.flutter.local
#
# Copy this file to .env.flutter.local and fill in real values.
# .env.flutter.local is gitignored and must never be committed.
#
# This file is for Flutter app runtime env variables ONLY.
# It must contain ONLY public RevenueCat SDK keys.
#
# !! DO NOT put REVENUECAT_WEBHOOK_SECRET in this file !!
# REVENUECAT_WEBHOOK_SECRET is a server-only secret for Cloud Functions.
# It must never be passed to Flutter via --dart-define.
# See functions/.secret.example and ENVIRONMENT_SETUP.md.
#
# Run Flutter with this file:
#   flutter run -d <device> --dart-define-from-file=.env.flutter.local

# ── RevenueCat public SDK keys ────────────────────────────────────────────────
# Obtain from: RevenueCat Dashboard > Project > Apps > (your app) > API keys
# These are public keys — safe in client builds, but never hardcode in source.
REVENUECAT_IOS_API_KEY=appl_replace_with_public_ios_sdk_key
REVENUECAT_ANDROID_API_KEY=goog_replace_with_public_android_sdk_key
